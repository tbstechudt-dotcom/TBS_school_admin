# Auto detect text files and normalize line endings
* text=auto

# Dart files
*.dart text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Web files
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.wasm binary
